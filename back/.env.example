# Porta do servidor
PORT=3000

# String de conexão do MongoDB
MONGO_URI=mongodb://localhost:27017/restaurantes

# Segredo utilizado para assinar os tokens JWT (troque por um valor forte em produção)
JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN=1d
JWT_SECRET_REFRESH=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN_REFRESH=1d

ENABLE_VISITORS=false
VISITORS_USERNAME=visitor
